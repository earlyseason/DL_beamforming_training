# ============================================================
# .gitignore — 波束选择项目的版本控制忽略规则
# ============================================================

# ===================== 数据文件 =====================
# DeepMIMO 原始场景数据（几百 MB，从官网下载，不应纳入版本控制）
deepmimo_scenarios/

# 生成的训练数据集（程序产生，可重新生成）
data/

# ===================== 运行产生文件 =====================
# 训练结果、模型权重、可视化图表（程序产生）
results/

# 模型 checkpoint
*.pth
*.pt
*.ckpt

# ===================== Python 环境与缓存 =====================
# Python 字节码缓存
__pycache__/
*.py[cod]
*$py.class
*.so

# 虚拟环境
venv/
env/
.venv/
.env/

# pip 包构建产物
build/
dist/
*.egg-info/
*.egg

# DeepMIMO 源码（已用 pip install -e . 安装到环境，不需要纳入项目仓库）
DeepMIMO/

# ===================== Jupyter / IDE =====================
# Jupyter notebook checkpoints
.ipynb_checkpoints/

# IDE 配置
.vscode/
.idea/
*.swp
*.swo

# ===================== 系统文件 =====================
# Windows
Thumbs.db
Desktop.ini

# macOS
.DS_Store

# ===================== 临时与日志 =====================
*.log
*.tmp
*.bak
.cache/

# ===================== 大型数据格式 =====================
*.npy
*.npz
*.mat
*.h5
*.hdf5
